<UserControl x:Class="Ndt.UI.Wpf.DocumentInsights"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ndt.UI.Wpf"
             xmlns:vm="clr-namespace:Ndt.UI.Wpf.ViewModels"
             xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:DocumentInsightsViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:StringEqualsConverter x:Key="StringEqualsConverter" />
        <local:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter" />
        <local:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />
        <Style x:Key="LabCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
        <Style x:Key="InsightButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="DOCUMENT INSIGHTS" FontSize="20" FontWeight="Bold" Foreground="#007ACC" VerticalAlignment="Center"/>
                <TextBlock Text=" | Automated NDT Technical Analysis" FontSize="14" Foreground="#888888" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource LabCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Technical Document" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>
                        
                        <Grid Cursor="Hand">
                            <Rectangle Stroke="#666666" StrokeThickness="2" StrokeDashArray="2 2" RadiusX="5" RadiusY="5" Fill="#2D2D2D"/>
                            <Button Command="{Binding UploadDocumentCommand}" Background="Transparent" BorderThickness="0" Padding="20">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📄" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Drag &amp; Drop or Browse" Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                                    <TextBlock Text=".txt files supported" FontSize="10" Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="#AAAAAA" TextWrapping="Wrap" FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource LabCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Insight Type" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>
                        
                        <UniformGrid Columns="3">
                            <RadioButton Style="{StaticResource InsightButtonStyle}" Content="Summary" IsChecked="{Binding SelectedInsightType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Summary}"/>
                            <RadioButton Style="{StaticResource InsightButtonStyle}" Content="Actions" IsChecked="{Binding SelectedInsightType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=ActionItems}"/>
                            <RadioButton Style="{StaticResource InsightButtonStyle}" Content="Topics" IsChecked="{Binding SelectedInsightType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=Topics}"/>
                        </UniformGrid>

                        <Button Command="{Binding AnalyzeDocumentCommand}" Margin="0,20,0,0" Padding="15" Background="#007ACC" Foreground="White" FontWeight="Bold" Content="ANALYZE DOCUMENT">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource LabCardStyle}" Margin="0,10,10,10">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding InsightResult, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                        <TextBlock Text="Awaiting Analysis..." FontSize="18" Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                        <TextBlock Text="Upload a document and select an insight type to begin." Foreground="#888888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#333333" Foreground="#007ACC" BorderThickness="0"/>
                        <TextBlock Text="Analyzing technical document..." Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsProcessing, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                        <md:MarkdownViewer Markdown="{Binding InsightResult}"
                                           TextElement.Foreground="#E0E0E0"
                                           TextElement.FontSize="14"
                                           TextElement.FontFamily="Segoe UI"
                                           Background="Transparent">
                            <md:MarkdownViewer.Resources>
                                
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1E1E1E" /> <Setter Property="BorderBrush" Value="#444444" /> <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="CornerRadius" Value="4" />
                                    <Setter Property="Padding" Value="15" />
                                    <Setter Property="Margin" Value="0,10,0,10" />
                                    <Setter Property="TextElement.Foreground" Value="#E0E0E0" />
                                    <Setter Property="TextElement.FontFamily" Value="Consolas" /> </Style>

                                <Style TargetType="FlowDocument">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                
                                <Style TargetType="Table">
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                                
                                <Style TargetType="TableCell">
                                    <Setter Property="BorderBrush" Value="#444444" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="5" />
                                </Style>
                            </md:MarkdownViewer.Resources>
                        </md:MarkdownViewer>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>