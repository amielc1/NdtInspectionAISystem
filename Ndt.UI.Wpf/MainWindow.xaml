<Window x:Class="Ndt.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ndt.UI.Wpf"
        xmlns:vm="clr-namespace:Ndt.UI.Wpf.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="NDT Inspection System" Height="800" Width="1200">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- Top Toolbar -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Load Image" Command="{Binding LoadImageCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Linear Stretch" Command="{Binding ApplyLinearStretchCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Equalized Stretch" Command="{Binding ApplyEqualizedStretchCommand}" Padding="10,5" Margin="0,0,5,0"/>
        </StackPanel>

        <!-- Left Column: Vision -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Background="Black">
                <Canvas x:Name="ImageCanvas"
                        Background="Transparent"
                        MouseDown="OnImageMouseDown"
                        MouseMove="OnImageMouseMove"
                        MouseUp="OnImageMouseUp"
                        ClipToBounds="True">
                    <Image x:Name="MainImage"
                           Source="{Binding DisplayImage}"
                           Stretch="Uniform"
                           Width="{Binding ActualWidth, ElementName=ImageCanvas}"
                           Height="{Binding ActualHeight, ElementName=ImageCanvas}" />
                    <Rectangle x:Name="RoiRectangle"
                               Stroke="Red"
                               StrokeThickness="2"
                               Visibility="Collapsed" />
                </Canvas>
            </Border>

            <GroupBox Grid.Row="1" Header="Detected Defects" Margin="0,10,0,0">
                <DataGrid ItemsSource="{Binding Defects}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                        <DataGridTextColumn Header="Area" Binding="{Binding Area, StringFormat={}{0:F1}}" Width="*"/>
                        <DataGridTextColumn Header="Position" Binding="{Binding CenterPoint}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- Right Column: AI Chat/Analysis -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Header="AI Analysis/Chat" Grid.Row="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding AnalysisSummary}" 
                               TextWrapping="Wrap" 
                               Padding="10" 
                               FontSize="14"/>
                </ScrollViewer>
            </GroupBox>

            <TextBox Grid.Row="1" 
                     Text="{Binding UserQuestion, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,10,0,0" 
                     Padding="5" 
                     Height="60" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"
                     VerticalContentAlignment="Top">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="Ask about the weld..." Foreground="Gray" FontStyle="Italic"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Button Grid.Row="2" 
                    Content="Analyze/Ask" 
                    Command="{Binding AnalyzeCommand}" 
                    Margin="0,5,0,0" 
                    Padding="10,10"
                    FontWeight="Bold"/>
        </Grid>

        <!-- Footer -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="100" 
                                 Height="15" 
                                 Margin="0,0,10,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
