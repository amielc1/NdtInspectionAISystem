<Window x:Class="Ndt.UI.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ndt.UI.Wpf"
        xmlns:vm="clr-namespace:Ndt.UI.Wpf.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="NDT Inspection System" Height="800" Width="1200" >
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Load Image" Command="{Binding LoadImageCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Linear Stretch" Command="{Binding ApplyLinearStretchCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Equalized Stretch" Command="{Binding ApplyEqualizedStretchCommand}" Padding="10,5" Margin="0,0,5,0"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Weld Vision">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Vision -->
                    <Grid Grid.Column="0" Margin="0,10,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Background="Black">
                            <Canvas x:Name="ImageCanvas"
                                    Background="Transparent"
                                    MouseDown="OnImageMouseDown"
                                    MouseMove="OnImageMouseMove"
                                    MouseUp="OnImageMouseUp"
                                    ClipToBounds="True">
                                <Image x:Name="MainImage"
                                       Source="{Binding DisplayImage}"
                                       Stretch="Uniform"
                                       Width="{Binding ActualWidth, ElementName=ImageCanvas}"
                                       Height="{Binding ActualHeight, ElementName=ImageCanvas}" />
                                <Rectangle x:Name="RoiRectangle"
                                           Stroke="Red"
                                           StrokeThickness="2"
                                           Visibility="Collapsed" />
                            </Canvas>
                        </Border>

                        <GroupBox Grid.Row="1" Header="Detected Defects" Margin="0,10,0,0">
                            <DataGrid ItemsSource="{Binding Defects}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                                    <DataGridTextColumn Header="Area" Binding="{Binding Area, StringFormat={}{0:F1}}" Width="*"/>
                                    <DataGridTextColumn Header="Position" Binding="{Binding CenterPoint}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>

                    <!-- Right Column: AI Chat/Analysis -->
                    <Grid Grid.Column="1" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="AI Analysis/Chat" Grid.Row="0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ChatHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="5" Padding="8" CornerRadius="5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Sender}" Value="User">
                                                                <Setter Property="Background" Value="#2D2D2D"/>
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                <Setter Property="Margin" Value="40,5,5,5"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Sender}" Value="AI">
                                                                <Setter Property="Background" Value="#3E3E3E"/>
                                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                                <Setter Property="Margin" Value="5,5,40,5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Sender}" 
                                                               FontSize="10" 
                                                               Foreground="Gray" 
                                                               Margin="0,0,0,4"/>
                                                    <TextBox Text="{Binding Content, Mode=OneWay}" 
                                                             TextWrapping="Wrap" 
                                                             FontSize="14" 
                                                             Foreground="LightGray" 
                                                             IsReadOnly="True" 
                                                             Background="Transparent" 
                                                             BorderThickness="0" 
                                                             Padding="0"
                                                             VerticalScrollBarVisibility="Disabled"/>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat=t}" 
                                                               FontSize="10" 
                                                               Foreground="Gray" 
                                                               HorizontalAlignment="Right" 
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </GroupBox>

                        <TextBox Grid.Row="1" 
                                 x:Name="QuestionTextBox"
                                 Text="{Binding UserQuestion, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,10,0,0" 
                                 Padding="5" 
                                 Height="60" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="False"
                                 VerticalContentAlignment="Top">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SendQuestionCommand}"/>
                            </TextBox.InputBindings>
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Ask about the weld..." Foreground="Gray" FontStyle="Italic"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="Background" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <UniformGrid Grid.Row="2" Columns="2" Margin="0,5,0,0">
                            <StackPanel Orientation="Vertical">
                                <CheckBox Content="Send with image" IsChecked="{Binding UseImageInChat}" Margin="0,5,0,5"/>
                                <CheckBox Content="RAG Mode" IsChecked="{Binding IsRagMode}" Margin="0,5,0,5"/>
                                <Button Content="Load RAG Content" Command="{Binding LoadRagContentCommand}" Margin="0,0,5,5" Padding="5,2" HorizontalAlignment="Left"/>
                                <UniformGrid Columns="2">
                                    <Button Content="Manual" 
                                            Command="{Binding AnalyzeManualCommand}" 
                                            Padding="10,10"
                                            Margin="0,0,2,0"
                                            FontWeight="Bold"/>
                                    <Button Content="AI Scan" 
                                            Command="{Binding AnalyzeWithAiCommand}" 
                                            Padding="10,10"
                                            Margin="2,0,2,0"
                                            Background="DarkSlateBlue"
                                            Foreground="White"
                                            FontWeight="Bold"/>
                                </UniformGrid>
                            </StackPanel>
                            <Button Content="Ask"  
                                    Command="{Binding SendQuestionCommand}" 
                                    Padding="10,10"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Bottom"
                                    FontWeight="Bold"/>
                        </UniformGrid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Chroma Management">
                <Grid Background="#1E1E1E">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20,15">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="CHROMA MANAGEMENT" FontSize="20" FontWeight="Bold" Foreground="#007ACC" VerticalAlignment="Center"/>
                            <TextBlock Text=" | Knowledge Base Import" FontSize="14" Foreground="#888888" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Border Background="#252525" BorderBrush="#444444" BorderThickness="1" CornerRadius="8" Padding="20" Margin="10">
                                <StackPanel>
                                    <TextBlock Text="Import Parameters" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>

                                    <TextBlock Text="Collection Name" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                                    <TextBox Text="{Binding ImportCollectionName, UpdateSourceTrigger=PropertyChanged}" 
                                             Background="#2D2D2D" Foreground="White" BorderBrush="#444444" Padding="8"/>

                                    <Button Command="{Binding LoadFileForImportCommand}" Margin="0,20,0,0" Padding="10" Background="#333333" Foreground="White" Content="LOAD FROM FILE"/>

                                    <Button Command="{Binding ImportContentCommand}" Margin="0,10,0,0" Padding="15" Background="#007ACC" Foreground="White" FontWeight="Bold" Content="IMPORT TO CHROMA DB"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="1" Background="#252525" BorderBrush="#444444" BorderThickness="1" CornerRadius="8" Padding="20" Margin="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Document Content" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>
                                <TextBox Grid.Row="1" 
                                         Text="{Binding ImportText, UpdateSourceTrigger=PropertyChanged}" 
                                         AcceptsReturn="True" 
                                         VerticalScrollBarVisibility="Auto" 
                                         TextWrapping="Wrap"
                                         Background="#2D2D2D" 
                                         Foreground="LightGray" 
                                         BorderBrush="#444444"
                                         Padding="10"
                                         FontSize="14"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Document Insights">
                <local:DocumentInsights DataContext="{Binding DocumentInsightsViewModel}"/>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="100" 
                                 Height="15" 
                                 Margin="0,0,10,0"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
